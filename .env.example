# Siigo API
SIIGO_AUTH_URL=https://api.siigo.com/auth
SIIGO_API_BASE_URL=https://api.siigo.com/v1
SIIGO_CLIENT_ID=tu_client_id_siigo
SIIGO_CLIENT_SECRET=tu_client_secret_siigo
SIIGO_PARTNER_ID=fedesoftcarterasiigo

# --- Prueba con UNA empresa (recomendado antes del sync completo) ---
# 1) Pon el NIT igual que en HubSpot (propiedad nit2), sin puntos ni guiones si asi esta en Siigo.
# 2) SYNC_DRY_RUN=true la primera vez para ver logs sin escribir en HubSpot.
# 3) SIIGO_INVOICES_MAX_PAGES=1 suele bastar; si esa empresa tiene muchas facturas, sube el numero o quitalo.
# TEST_ONLY_NIT=900123456
# SYNC_DRY_RUN=true
# SIIGO_INVOICES_MAX_PAGES=1

# --- Sync completo en produccion ---
# Quita o comenta TEST_ONLY_NIT, SYNC_DRY_RUN y SIIGO_INVOICES_MAX_PAGES.
# Opcional: SYNC_INTERVAL_MINUTES=360 y luego docker compose up -d

# HubSpot API
HUBSPOT_ACCESS_TOKEN=tu_token_privado_hubspot
HUBSPOT_API_BASE_URL=https://api.hubapi.com

# Base de datos interna (requerida para APP_MODE=scheduler o APP_MODE=worker)
# En Docker Compose local, usa el servicio postgres:
# DATABASE_URL=postgresql://postgres:postgres@postgres:5432/cartera_sync

# Seguimiento de afiliacion (select una opcion en empresas). Opcional: si no defines PROPERTY, no se actualiza.
# En HubSpot: nombre interno de la propiedad y los "valores" internos de cada opcion (no siempre igual al texto visible).
# HUBSPOT_SEGUIMIENTO_AFILIACION_PROPERTY=seguimiento_afiliacion
# Deben ser los valores permitidos por HubSpot (suelen ser las etiquetas visibles del desplegable).
# HUBSPOT_SEGUIMIENTO_AFILIACION_MORA="En mora"
# HUBSPOT_SEGUIMIENTO_AFILIACION_AL_DIA="Afiliado al día"

# Opcionales (valores por defecto entre paréntesis)
# HTTP_TIMEOUT_MS=30000
# HTTP_RETRIES=3

# Modo automático: sync cada N minutos (recomendado para Docker “siempre activo”).
# Si no lo defines, el proceso hace un solo sync y termina (ideal para cron o ejecución manual).
# SYNC_INTERVAL_MINUTES=360

# Modos de ejecución:
# APP_MODE=sync       -> flujo tradicional
# APP_MODE=scheduler  -> crea corridas y jobs en Postgres
# APP_MODE=worker     -> consume jobs NIT por NIT
# APP_MODE=sync
#
# Polling / reintentos worker
# WORKER_POLL_MS=5000
# WORKER_MAX_ATTEMPTS=3
# WORKER_RETRY_DELAY_MS=30000
#
# Límite opcional de NITs encolados por corrida automática
# SCHEDULER_BATCH_LIMIT=1000

